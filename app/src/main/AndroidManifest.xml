<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WellnessApp"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.WellnessApp.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".activities.RegisterActivity" />
        <activity android:name=".activities.RegisterStep2Activity" />
        <activity android:name=".activities.ListViewActivity" />
        <activity android:name=".activities.EditActivity" />
        <activity android:name=".activities.DeleteActivity" />
        <activity
            android:name=".activities.DashboardActivity"
            android:exported="true" />
        <activity
            android:name=".activities.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activities.HistoryTrendActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Author: Si Hua, Why: Android refuses to launch unregistered activities. So add this -->
        <activity android:name=".activities.AddRecordActivity" />
        <activity android:name=".activities.CategoryPickerActivity" />
        <activity android:name=".activities.LogCategoryActivity" />

        <receiver
            android:name=".notification.ReminderReceiver"
            android:exported="false" />

        <activity
            android:name=".activities.NotificationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activities.NotificationSetupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
    </application>

</manifest>