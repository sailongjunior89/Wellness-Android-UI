<?xml version="1.0" encoding="utf-8"?>
<!-- Author : Tan Pang Wee-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp"
        android:background="#FFF7FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="30dp"
            android:paddingLeft="30dp"
            android:paddingRight="30dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="1dp"
                android:src="@drawable/ic_chevron_left"
                android:contentDescription="Back" />

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginBottom="24dp"
                android:contentDescription="TODO"
                android:padding="0dp"
                android:layout_gravity="center_horizontal"
                android:src="@android:color/transparent"
                android:scaleType="fitCenter" />

            <!--            <ProgressBar-->
            <!--                android:id="@+id/progressBar"-->
            <!--                style="?android:attr/progressBarStyle"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="wrap_content" />-->

            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="24sp"
                android:hint="Category"
                android:inputType="text"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:clickable="false"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date"
                    android:layout_weight="2"
                    android:inputType="date"
                    android:layout_marginTop="12dp"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:cursorVisible="false"
                    android:clickable="false"/>
                <EditText
                    android:id="@+id/etRecordDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Date"
                    android:layout_weight="1"
                    android:inputType="date"
                    android:layout_marginTop="12dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <EditText
                    android:id="@+id/etUnit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Unit"
                    android:inputType="text" />
                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />
                <EditText
                    android:id="@+id/etValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:hint="Value"
                    android:inputType="numberDecimal" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <EditText
                    android:id="@+id/etDurationLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Duration-min"
                    android:layout_weight="2"
                    android:inputType="numberDecimal"
                    android:layout_marginTop="12dp" />
                <EditText
                    android:id="@+id/etDuration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Duration-min"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">
                <EditText
                    android:id="@+id/etCaloriesLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:layout_weight="2"
                    android:inputType="number"
                    android:layout_marginTop="12dp" />
                <EditText
                    android:id="@+id/etCalories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Calories"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notes :"
                android:gravity="start"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="5dp"
                android:textSize="18sp" />
            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="Notes"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginTop="0dp" />

            <Button
                android:id="@+id/btnGetRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get Record"
                android:layout_marginTop="24dp" />

            <Button
                android:id="@+id/btnUpdateRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update Record"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/txtRecordId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textSize="8sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>

    </FrameLayout>

</FrameLayout>